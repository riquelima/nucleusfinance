{
  "version": 2,
  "name": "nucleus-cleaning-services",
  "cleanUrls": true,
  "framework": null,
  "routes": [
    {
      "src": "^/$",
      "dest": "/dashboard.html"
    },
    {
      "src": "^/index(\\.html)?$",
      "dest": "/dashboard.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
